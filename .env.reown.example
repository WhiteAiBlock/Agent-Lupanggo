# Reown App Environment Configuration
# 
# This is a template file showing all available environment variables.
# Copy to .env.local and fill in with actual values.
# NEVER commit sensitive values to git.

# ============================================================================
# REOWN CONFIGURATION
# ============================================================================
# Get these from https://cloud.reown.com

# Your Reown/WalletConnect project ID
# Generate at: https://cloud.reown.com/apps
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here

# Your Reown secret key (KEEP SECRET!)
# Get from: https://cloud.reown.com > Settings > API Keys
REOWN_SECRET_KEY=your_reown_secret_key_here

# ============================================================================
# SOLANA CONFIGURATION
# ============================================================================

# Solana RPC endpoint
# Devnet:  https://api.devnet.solana.com
# Testnet: https://api.testnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
# Helius:  https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Alchemy: https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# Network identifier for Solana
# Options: devnet, testnet, mainnet-beta
SOLANA_NETWORK=devnet

# ============================================================================
# API KEYS & THIRD-PARTY SERVICES
# ============================================================================

# Alchemy API key for enhanced RPC features
# Get from: https://dashboard.alchemy.com
# Optional but recommended
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Helius API key for Solana indexing and parsing
# Get from: https://dashboard.helius.dev
# Optional but recommended
HELIUS_API_KEY=your_helius_api_key_here

# QuickNode API key (alternative RPC provider)
# Get from: https://www.quicknode.com
# Optional
QUICKNODE_API_KEY=your_quicknode_api_key_here

# Moralis API key for blockchain data
# Get from: https://moralis.io
# Optional
MORALIS_API_KEY=your_moralis_api_key_here

# ============================================================================
# WALLET & AUTHORITY CONFIGURATION
# ============================================================================

# Deployer keypair (Base58 encoded)
# IMPORTANT: This is sensitive! Never commit to git
# Generate with: solana-keygen new
DEPLOYER_KEYPAIR=your_deployer_keypair_base58_here

# Treasury/DAO wallet public address
# Format: 44-character Solana address (base58)
# Example: zhBqbd9tSQFPevg4188JxcgpccCj3t1Jxb29zsBc2R4
TREASURY_PUBKEY=your_treasury_public_key_here

# Relayer address for gas-less transactions
# Optional: Use for Biconomy integration
RELAYER_PUBKEY=your_relayer_public_key_here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment
# Options: development, staging, production
NODE_ENV=development

# Frontend application URL
# Development: http://localhost:3000
# Staging:    https://staging.example.com
# Production: https://app.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API URL
# Development: http://localhost:3001
# Production: https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database connection string (if applicable)
DATABASE_URL=postgresql://user:password@localhost:5432/reown_app

# Session secret for authentication
SESSION_SECRET=your_random_session_secret_here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable WalletConnect/Reown integration
# Options: true, false
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true

# Enable wallet auto-connection on page load
NEXT_PUBLIC_AUTO_CONNECT_WALLET=true

# Enable analytics and tracking
# Options: true, false
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Enable debug logging in console
NEXT_PUBLIC_DEBUG_MODE=false

# Enable experimental features
NEXT_PUBLIC_ENABLE_EXPERIMENTAL=false

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Google Analytics ID
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here

# Segment Analytics key
NEXT_PUBLIC_SEGMENT_KEY=your_segment_key_here

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# LogRocket session recording
NEXT_PUBLIC_LOGROCKET_ID=your_logrocket_id_here

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Rate limiting per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT secret for token signing
JWT_SECRET=your_jwt_secret_here

# Encryption key for sensitive data
ENCRYPTION_KEY=your_encryption_key_here

# ============================================================================
# BLOCKCHAIN CONSTANTS
# ============================================================================

# Token mint addresses
# Example: USDC mint on Solana
NEXT_PUBLIC_USDC_MINT=EPjFWaLb3ufEi6Q8r3Vc6KUrat5VEJw5Cwupa5DvvXJL

# Program IDs
NEXT_PUBLIC_VOTE_PROGRAM_ID=your_vote_program_id_here
NEXT_PUBLIC_NFT_PROGRAM_ID=your_nft_program_id_here

# Contract addresses
NEXT_PUBLIC_TREASURY_VAULT=your_treasury_vault_address_here
NEXT_PUBLIC_VOTING_VAULT=your_voting_vault_address_here

# ============================================================================
# ADVANCED FEATURES
# ============================================================================

# Enable MPC (Multi-Party Computation) signing
NEXT_PUBLIC_ENABLE_MPC=false

# MPC Configuration
MPC_THRESHOLD=3
MPC_TOTAL_SHARES=5

# Enable DAO governance features
NEXT_PUBLIC_ENABLE_GOVERNANCE=true

# Enable NFT support
NEXT_PUBLIC_ENABLE_NFT=true

# Enable token swaps (Jupiter integration)
NEXT_PUBLIC_ENABLE_SWAPS=true

# Enable staking
NEXT_PUBLIC_ENABLE_STAKING=false

# ============================================================================
# SECURITY SCANNING
# ============================================================================

# Snyk token for security vulnerability scanning
# Get from: https://snyk.io
SNYK_TOKEN=your_snyk_token_here

# WhiteSource Bolt for dependency scanning
WHITESOURCE_API_KEY=your_whitesource_key_here

# ============================================================================
# BUILD & DEPLOYMENT
# ============================================================================

# Skip build optimization (for debugging)
NEXT_SKIP_BUILD=false

# Enable source maps in production
NEXT_SOURCE_MAPS=false

# Enable React strict mode
REACT_STRICT_MODE=true

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
#    Do NOT include sensitive information in public variables
# 
# 2. All other variables are server-side only and private
# 
# 3. Always use .env.local (or .env.local.example) for local development
#    Never commit actual secrets to the repository
# 
# 4. For CI/CD, set secrets via GitHub Settings > Secrets and variables
# 
# 5. Rotate sensitive keys regularly:
#    - API keys: Every 3-6 months
#    - Session secrets: When detected/compromised
#    - Keypairs: After each deployment
# 
# 6. Document any custom environment variables your app needs
# 
# 7. Use strong, random values for all secrets
#    Generate with: openssl rand -base64 32
# 
# ============================================================================
