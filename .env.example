# OMEGA PRIME DEPLOYER - ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# Core Configuration
RPC_URL=https://api.mainnet-beta.solana.com
WSS_URL=wss://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here

# Relayer Network
RELAYER_URL=https://your-relayer-domain/relay/sendRawTransaction
RELAYER_PUBKEY=your_relayer_fee_payer_pubkey_here
RELAYER_API_KEY=your_relayer_api_key_here

# Wallet Addresses (NEVER use real addresses in this file)
TREASURY_PUBKEY=EXAMPLE_TREASURY_PUBKEY_HERE
COCREATOR_PUBKEY=EXAMPLE_COCREATOR_PUBKEY_HERE
MINT_ADDRESS=EXAMPLE_MINT_ADDRESS_HERE
REINVEST_ADDRESS=EXAMPLE_REINVEST_ADDRESS_HERE

# Agent Bot Configuration
BOT_1_PUBKEY=EXAMPLE_BOT_1_PUBKEY
BOT_2_PUBKEY=EXAMPLE_BOT_2_PUBKEY
BOT_3_PUBKEY=EXAMPLE_BOT_3_PUBKEY
BOT_4_PUBKEY=EXAMPLE_BOT_4_PUBKEY
BOT_5_PUBKEY=EXAMPLE_BOT_5_PUBKEY
BOT_6_PUBKEY=EXAMPLE_BOT_6_PUBKEY
BOT_7_PUBKEY=EXAMPLE_BOT_7_PUBKEY
BOT_8_PUBKEY=EXAMPLE_BOT_8_PUBKEY

# Helius Integration & Rebates
WEBHOOK_URL=https://your-webhook-endpoint.com/helius
HELIUS_REBATES_ENABLED=true
TIP_ACCOUNT_OVERRIDE=custom_tip_account_pubkey_here
MEV_PROTECTION_ENABLED=true

# Jupiter Integration
JUPITER_PROGRAM_ID=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
IMPULSE_MINT=EXAMPLE_IMPULSE_MINT_ADDRESS
OMEGA_MINT=EXAMPLE_OMEGA_MINT_ADDRESS

# Rebate Distribution
REBATE_AUTO_DISTRIBUTE=true
TREASURY_CUT_PERCENTAGE=0.15
REBATE_ANNOUNCEMENT_ENABLED=true

# ATP Integration
ATP_ENABLED=true
ATP_MINT_LOGIC=true
ATP_CONTRACT_LOGIC=true

# Initial Investment Airdrop
AIRDROP_ENABLED=true
IMPULSE_AIRDROP_AMOUNT=10000
OMEGA_AIRDROP_AMOUNT=5000
INITIAL_INVESTOR_LIST=EXAMPLE_COMMA_SEPARATED_ADDRESSES

# Investor Lure Bot
AUTO_LURE_ENABLED=true
LURE_BOT_ADDRESS=EXAMPLE_BOT_1_PUBKEY
LURE_INTERVAL_MINUTES=5
MAINNET_ANNOUNCE_ENABLED=true

# DEX Proxy Deployment
DEX_PROXY_PROGRAM=6MWVTis8rmmk6Vt9zmAJJbmb3VuLpzoQ1aHH4N6wQEGh
BOT_1_EXECUTOR=EXAMPLE_BOT_1_EXECUTOR
ALL_IN_ONE_ENABLED=true

# Gene NFT Activation
GENE_NFT_ENABLED=true
NFT_COLLECTION_SIZE=5
GENE_NFT_REBATES=true

# Bot Army NFT Minting
PROXY_MINT_ALL=true

# Locked Configuration
CONFIG_LOCKED=true
LOCK_OVERRIDE_ENABLED=true
PERMANENT_REBATES=true
PERMANENT_MEV=true

# CRITICAL SECURITY WARNING:
# NEVER put real private keys in this file or commit them to git
# Use GitHub Secrets or secure environment variable management
DEPLOYER_PRIVATE_KEY=NEVER_PUT_REAL_PRIVATE_KEY_HERE

# ============================================================================
# RALPH AGENT BOT CONFIGURATION (Feb 2026)
# Agentic Ancient Alien – Cyberpunk Solana Empire Builder
# ============================================================================

# Ralph Execution
RALPH_ENABLED=true
RALPH_NETWORK=solana-mainnet
RALPH_UPDATE_INTERVAL=1h
RALPH_LOG_DIR=./logs

# Strategy Parameters
YIELD_HARVESTER_ENABLED=true
YIELD_HARVESTER_FREQUENCY=6h
YIELD_MIN_APY=5
YIELD_MIN_COMPOUND_GAIN=0.01

SIGNAL_SEEKER_ENABLED=false
SIGNAL_SEEKER_FREQUENCY=5m
SIGNAL_MIN_SENTIMENT=0.6
SIGNAL_MIN_VELOCITY=50

LIQUIDITY_SNIFFER_ENABLED=false
LIQUIDITY_SNIPER_MAX_RISK=0.7
LIQUIDITY_SNIPER_MIN_VOLUME=1000

ZK_FARMER_ENABLED=false
ZK_FARMER_FREQUENCY=daily
ZK_MIN_AIRDROP_VALUE=10

BELIEF_REWRITE_ENABLED=false
BELIEF_REWRITE_FREQUENCY=weekly
BELIEF_LOOKBACK_DAYS=7
BELIEF_MUTATION_RATE=0.1

# Risk Management
RALPH_MAX_POSITION_SIZE=10000
RALPH_MAX_LEVERAGE=1.0
RALPH_MIN_BALANCE=0.5
RALPH_MAX_DAILY_LOSS=0.05
RALPH_STOP_LOSS=0.02

# Database (for Ralph state tracking)
RALPH_DATABASE_URL=postgresql://user:password@localhost/ralph
RALPH_DB_ENABLED=false

# Alerts & Notifications
RALPH_DISCORD_WEBHOOK=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID
RALPH_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR_WEBHOOK
RALPH_EMAIL_ALERTS=your-email@example.com

# Twitter/X API (for Signal Seeker)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_BEARER_TOKEN=your_bearer_token

# Discord API (for Signal Seeker)
DISCORD_BOT_TOKEN=your_discord_bot_token

# Dashboard
RALPH_DASHBOARD_ENABLED=true
RALPH_DASHBOARD_PORT=3000