# Cloud AI Agent Configuration

# AI Provider: 'ollama' (free, local/cloud) or 'claude' (Anthropic API)
AI_PROVIDER=ollama

# Ollama Configuration (FREE - run locally or use cloud instance)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Claude AI Configuration (Anthropic - requires API key)
# Get free tier at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Quick Setup:
# 1. For Ollama (FREE):
#    - Install: curl -fsSL https://ollama.com/install.sh | sh
#    - Run: ollama run llama2
#    - Set AI_PROVIDER=ollama
#
# 2. For Claude AI:
#    - Get API key from https://console.anthropic.com/
#    - Set ANTHROPIC_API_KEY=your_key_here
#    - Set AI_PROVIDER=claude
